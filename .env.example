# ==============================================
# RAPIGO MALI — Variables d'environnement
# ==============================================
# Copiez ce fichier en .env et remplissez les valeurs

# --- Base de données ---
# SQLite (VPS/Docker local)
DATABASE_URL="file:/app/data/rapigo.db"

# --- Sécurité ---
# IMPORTANT: Changez cette clé ! Utilisez une chaîne de 32+ caractères aléatoires
# Générez-en une avec: openssl rand -base64 32
JWT_SECRET="CHANGEZ-MOI-avec-une-cle-secrete-de-32-caracteres-minimum"

# --- Application ---
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"
NODE_ENV="production"
PORT=3000

# --- Supabase (optionnel — pour le stockage d'images) ---
# SUPABASE_URL="https://votre-projet.supabase.co"
# SUPABASE_ANON_KEY="votre-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key"

# --- Rapigo Pay (optionnel) ---
# ORANGE_MONEY_API_KEY=""
# MOOV_MONEY_API_KEY=""
# WAVE_API_KEY=""