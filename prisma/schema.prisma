// Rapigo Mali V2.5 Enterprise - Database Schema
// Delivery Platform for Mali/West Africa

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & ROLES
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  password      String
  firstName     String
  lastName      String
  avatar        String?
  role          String    @default("CLIENT") // CLIENT, MERCHANT, DRIVER, ADMIN
  isSuperAdmin  Boolean   @default(false)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client         Client?
  merchant       Merchant?
  driver         Driver?
  notifications  Notification[]
  wallets        Wallet[]
  sentMessages   Message[]  @relation("MessageSender")
  receivedMessages Message[] @relation("MessageRecipient")
  chats          Chat[]
  ratingsGiven   Rating[]  @relation("RatingGiven")
  auditLogs      AuditLog[]
  supportTickets SupportTicket[]
  payments       Payment[]
  reports        Report[]  @relation("ReportUser")
  referralsMade  Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referred")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
}

model Client {
  id            String   @id @default(cuid())
  userId        String   @unique
  address       String?
  city          String   @default("Bamako")
  quartier      String?
  loyaltyPoints Int      @default(0)
  totalSpent    Int      @default(0)
  totalOrders   Int      @default(0)
  referralCode  String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  favorites   Favorite[]
  coupons     CouponUsage[]
  reviews     Rating[]   @relation("ClientReview")

  @@index([userId])
  @@index([referralCode])
}

model Merchant {
  id              String    @id @default(cuid())
  userId          String    @unique
  businessName    String
  businessType    String    @default("RESTAURANT") // RESTAURANT, SUPERMARKET, PHARMACY, BOUTIQUE, COLIS, ELECTRONIQUE, MODE, BEAUTE
  description     String?
  shortDescription String?
  logo            String?
  coverImage      String?
  address         String
  city            String    @default("Bamako")
  quartier        String?
  phone           String
  email           String?
  website         String?
  operatingHours  String    @default("08:00-22:00")
  isApproved      Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  rating          Float     @default(0)
  totalRatings    Int       @default(0)
  commissionRate  Float     @default(0.10)
  minOrderAmount  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions  Subscription[]
  products       Product[]
  orders         Order[]
  advertisements Advertisement[]
  coupons        Coupon[]
  ratings        Rating[]
  reports        Report[]      @relation("ReportMerchant")
  deliveryZones  DeliveryZone[]
  paymentConfigs MerchantPaymentConfig[]

  @@index([userId])
  @@index([businessType])
  @@index([city])
  @@index([isApproved])
}

model Driver {
  id              String    @id @default(cuid())
  userId          String    @unique
  vehicleType     String    @default("MOTO") // MOTO, VELO, VOITURE
  vehiclePlate    String?
  vehicleBrand    String?
  vehicleColor    String?
  idCardNumber    String?
  licenseNumber   String?
  idCardImage     String?
  licenseImage    String?
  vehicleImage    String?
  selfieImage     String?
  isApproved      Boolean   @default(false)
  isOnline        Boolean   @default(false)
  isAvailable     Boolean   @default(false)
  rating          Float     @default(0)
  totalRatings    Int       @default(0)
  totalDeliveries Int       @default(0)
  totalEarnings   Int       @default(0)
  currentLat      Float?
  currentLng      Float?
  bonus           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      Delivery[]
  orders          Order[]
  locations       DriverLocation[]
  reviews         Rating[]    @relation("DriverReview")

  @@index([userId])
  @@index([isOnline])
  @@index([isAvailable])
  @@index([isApproved])
}

// ============================================
// CATEGORIES
// ============================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  image       String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

// ============================================
// PRODUCTS (Enhanced)
// ============================================

model Product {
  id               String   @id @default(cuid())
  merchantId       String
  categoryId       String?
  name             String
  slug             String   @unique
  shortDescription String?
  longDescription  String?
  price            Int
  comparePrice     Int?
  currency         String   @default("XOF")
  image            String?
  images           String?  // JSON array of image URLs
  video            String?
  sku              String?
  barcode          String?
  weight           String?
  dimensions       String?  // JSON: {length, width, height, unit}
  variants         String?  // JSON array of variants
  options          String?  // JSON: [{name, values, required}]
  supplements      String?  // JSON: [{name, price}]
  allergens        String?  // JSON array of strings
  tags             String?  // JSON array of strings
  brand            String?
  origin           String?
  stock            Int      @default(0)
  isAvailable      Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  preparationTime  Int?     // minutes
  rating           Float    @default(0)
  totalSold        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  merchant    Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  favorites   Favorite[]

  @@index([merchantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([isFeatured])
  @@index([slug])
  @@index([sku])
}

// ============================================
// DELIVERY ZONES (Merchant-defined pricing)
// ============================================

model DeliveryZone {
  id          String  @id @default(cuid())
  merchantId  String
  city        String  @default("Bamako")
  quartier    String?
  fee         Int
  currency    String  @default("XOF")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([city])
  @@index([quartier])
}

// ============================================
// MERCHANT PAYMENT CONFIG
// ============================================

model MerchantPaymentConfig {
  id              String  @id @default(cuid())
  merchantId      String
  method          String  // ORANGE_MONEY, MOOV_MONEY, WAVE, VISA, MASTERCARD, QR_CODE, CASH
  isEnabled       Boolean @default(false)
  phoneNumber     String? // For mobile money
  accountName     String? // Account holder name
  accountNumber   String? // For cards
  qrCode          String? // QR code image URL
  instructions    String? // Payment instructions for client
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, method])
  @@index([merchantId])
}

// ============================================
// ORDERS (Full flow)
// ============================================

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  clientId        String
  merchantId      String
  driverId        String?
  status          String    @default("PENDING") // PENDING, PAYMENT_PENDING, CONFIRMED, PREPARING, READY, ASSIGNED, PICKED_UP, IN_TRANSIT, DELIVERED, CANCELLED, REFUNDED
  subtotal        Int
  deliveryFee     Int       @default(0)
  serviceFee      Int       @default(0)
  discount        Int       @default(0)
  total           Int
  currency        String    @default("XOF")
  paymentMethod   String    @default("CASH") // CASH, ORANGE_MONEY, MOOV_MONEY, WAVE, VISA, MASTERCARD, QR_CODE, WALLET
  paymentStatus   String    @default("PENDING") // PENDING, UPLOADED, ACCEPTED, REJECTED, FAILED, REFUNDED
  paymentProof    String?   // Image URL of payment screenshot/receipt
  paymentNote     String?   // Client note about payment
  deliveryAddress String
  deliveryCity    String    @default("Bamako")
  deliveryQuartier String?
  deliveryLat     Float?
  deliveryLng     Float?
  notes           String?
  estimatedTime   Int?      // minutes
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client         Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  merchant       Merchant    @relation(fields: [merchantId], references: [id])
  driver         Driver?     @relation(fields: [driverId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  delivery       Delivery?
  ratings        Rating[]

  @@index([clientId])
  @@index([merchantId])
  @@index([driverId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  productImage String?
  quantity     Int
  unitPrice    Int
  totalPrice   Int
  variants     String? // JSON
  supplements  String? // JSON
  notes        String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Note: productId kept as String field (not relation) for simplicity with order snapshots

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id              String    @id @default(cuid())
  orderId         String
  userId          String
  amount          Int
  currency        String    @default("XOF")
  method          String    // CASH, ORANGE_MONEY, MOOV_MONEY, WAVE, VISA, MASTERCARD, QR_CODE, WALLET
  status          String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  transactionRef  String?   @unique
  providerRef     String?
  metadata        String?   // JSON
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([transactionRef])
}

// ============================================
// SUBSCRIPTIONS & PLANS
// ============================================

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Int
  currency    String   @default("XOF")
  duration    Int      @default(30) // days
  features    String?  // JSON array of features
  maxProducts Int?
  maxOrders   Int?
  maxCoupons  Int?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
}

model Subscription {
  id          String    @id @default(cuid())
  merchantId  String
  planId      String
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate   DateTime  @default(now())
  endDate     DateTime
  autoRenew   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@index([endDate])
}

// ============================================
// COUPONS & REFERRALS
// ============================================

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  merchantId  String?
  type        String    @default("PERCENTAGE") // PERCENTAGE, FIXED, FREE_DELIVERY
  value       Int
  minOrder    Int       @default(0)
  maxUses     Int?
  usedCount   Int       @default(0)
  startDate   DateTime  @default(now())
  endDate     DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  merchant   Merchant?     @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  usages     CouponUsage[]

  @@index([code])
  @@index([merchantId])
  @@index([isActive])
}

model CouponUsage {
  id          String   @id @default(cuid())
  couponId    String
  clientId    String
  orderId     String
  discount    Int
  createdAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([couponId])
  @@index([clientId])
  @@index([orderId])
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  code          String
  reward        Int      @default(0)
  isClaimed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])

  @@unique([referredId])
  @@index([referrerId])
  @@index([code])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, ORDER, PAYMENT, DELIVERY, PROMO, SYSTEM, SUPPORT, SUBSCRIPTION
  data      String?  // JSON
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// CHAT & MESSAGES
// ============================================

model Chat {
  id              String    @id @default(cuid())
  orderId         String?
  participantIds  String    // JSON array of user IDs
  lastMessage     String?
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages Message[]
  users    User[]

  @@index([orderId])
}

model Message {
  id           String   @id @default(cuid())
  chatId       String
  senderId     String
  recipientId  String?
  content      String
  type         String   @default("TEXT") // TEXT, IMAGE, LOCATION, SYSTEM
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  chat      Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User  @relation("MessageSender", fields: [senderId], references: [id])
  recipient  User? @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================
// RATINGS & REVIEWS
// ============================================

model Rating {
  id          String   @id @default(cuid())
  orderId     String   @unique
  clientId    String
  driverId    String?
  merchantId  String?
  score       Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  client   Client   @relation("ClientReview", fields: [clientId], references: [id])
  driver   Driver?  @relation("DriverReview", fields: [driverId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id])
  user     User     @relation("RatingGiven", fields: [clientId], references: [id])

  @@index([orderId])
  @@index([clientId])
  @@index([driverId])
  @@index([merchantId])
}

// ============================================
// WALLET & TRANSACTIONS
// ============================================

model Wallet {
  id         String  @id @default(cuid())
  userId     String  @unique
  balance    Int     @default(0)
  currency   String  @default("XOF")
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String   // CREDIT, DEBIT
  amount      Int
  currency    String   @default("XOF")
  description String
  reference   String?  @unique
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// DELIVERIES
// ============================================

model Delivery {
  id              String   @id @default(cuid())
  orderId         String   @unique
  driverId        String
  status          String   @default("ASSIGNED") // ASSIGNED, PICKING_UP, IN_TRANSIT, NEARBY, DELIVERED
  pickupLat       Float?
  pickupLng       Float?
  dropoffLat      Float?
  dropoffLng      Float?
  pickupAddress   String?
  dropoffAddress  String?
  estimatedDistance Int?
  actualDistance   Int?
  estimatedDuration Int?
  actualDuration   Int?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order  Order   @relation(fields: [orderId], references: [id])
  driver Driver  @relation(fields: [driverId], references: [id])

  @@index([orderId])
  @@index([driverId])
  @@index([status])
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String
  lat       Float
  lng       Float
  accuracy  Float?
  heading   Float?
  speed     Float?
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([createdAt])
}

// ============================================
// MARKETING
// ============================================

model Advertisement {
  id          String    @id @default(cuid())
  merchantId  String?
  title       String
  description String?
  image       String?
  link        String?
  type        String    @default("BANNER") // BANNER, POPUP, SIDEBAR
  position    String    @default("HOME") // HOME, CATEGORY, SEARCH, MERCHANT
  startDate   DateTime  @default(now())
  endDate     DateTime
  budget      Int       @default(0)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([isActive])
  @@index([position])
}

// ============================================
// SUPPORT & REPORTS
// ============================================

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  description String
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
}

model Report {
  id          String    @id @default(cuid())
  userId      String?
  merchantId  String?
  type        String
  title       String
  data        String?   // JSON
  period      String    @default("DAILY") // DAILY, WEEKLY, MONTHLY, YEARLY
  createdAt   DateTime  @default(now())

  user     User?     @relation("ReportUser", fields: [userId], references: [id])
  merchant Merchant? @relation("ReportMerchant", fields: [merchantId], references: [id])

  @@index([type])
  @@index([period])
  @@index([createdAt])
}

// ============================================
// SETTINGS & AUDIT
// ============================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("STRING") // STRING, NUMBER, BOOLEAN, JSON
  group String @default("GENERAL") // GENERAL, PAYMENT, DELIVERY, NOTIFICATION, SECURITY, COMMISSION, SUBSCRIPTION
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?  // JSON
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ============================================
// FAVORITES
// ============================================

model Favorite {
  id         String   @id @default(cuid())
  clientId   String
  productId  String
  createdAt  DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([clientId, productId])
  @@index([clientId])
  @@index([productId])
}